@page "/games/delete"
@using Microsoft.EntityFrameworkCore
@using BlazorWebAppGames.Models
@inject IDbContextFactory<BlazorWebAppGames.Data.BlazorWebAppGamesContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Games</h2>
    <hr />
    @if (games is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@games.Title</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Release Date</dt>
            <dd class="col-sm-10">@games.ReleaseDate</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">CoverImageURL</dt>
            <dd class="col-sm-10">@games.CoverImageURL</dd>
        </dl>

        // Display platforms as a comma-separated list
        <dl class="row">
            <dt class="col-sm-2">Platform</dt>
            <dd class="col-sm-10">
                @string.Join(", ", games.GamePlatforms.Select(gp => gp.Platform.Name))
            </dd>
        </dl>

        <dl class="row">
            <dt class="col-sm-2">Status</dt>
            <dd class="col-sm-10">@games.Status</dd>
        </dl>

        

        <EditForm method="post" Model="games" OnValidSubmit="DeleteGames" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(games is null)">Delete</button> |
            <a href="/games">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Game? games;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    // Load the game details on initialization
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        games = await context.Games
            .Include(g => g.GamePlatforms)
            .ThenInclude(gp => gp.Platform)
            .FirstOrDefaultAsync(m => m.Id == Id);

        if (games is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    // Method to delete the game and its related GamePlatforms
    private async Task DeleteGames()
    {
        using var context = DbFactory.CreateDbContext();

        var gameToDelete = await context.Games
            .Include(g => g.GamePlatforms)
            .FirstOrDefaultAsync(g => g.Id == Id);

        if (gameToDelete != null)
        {
            context.GamePlatforms.RemoveRange(gameToDelete.GamePlatforms);
            context.Games.Remove(gameToDelete);
            await context.SaveChangesAsync();
        }

        NavigationManager.NavigateTo("/games");
    }
}
