@page "/games/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorWebAppGames.Models
@inject IDbContextFactory<BlazorWebAppGames.Data.BlazorWebAppGamesContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Game</h2>
<hr />
@if (Games is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Games" OnValidSubmit="UpdateGames" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Games.Id" value="@Games.Id" />
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="title" class="form-label">Title:</label>
                    <InputText id="title" @bind-Value="Games.Title" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Games.Title" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="releasedate" class="form-label">Release Date:</label>
                    <InputDate id="releasedate" @bind-Value="Games.ReleaseDate" class="form-control" />
                    <ValidationMessage For="() => Games.ReleaseDate" class="text-danger" />
                </div>

                <!-- Dropdown for Platform -->
                <div class="mb-3">
                    <label for="platform" class="form-label">Platform:</label>
                    <InputSelect id="platform" @bind-Value="SelectedPlatformId" class="form-control">
                        <option value="">-- Select Platform --</option>
                        @foreach (var platform in Platforms)
                        {
                            <option value="@platform.Id">@platform.Name</option>
                        }
                    </InputSelect>
                </div>

                <!-- Dropdown for Game Status-->
                <div class="mb-3">
                    <label for="status" class="form-label">Status:</label>
                    <InputSelect id="status" @bind-Value="Games.Status" class="form-control">
                        @foreach (var status in Enum.GetValues<GameStatus>())
                        {
                            <option value="@status">@status</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Games.Status" class="text-danger" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/games">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private Game Games { get; set; } = default!;

    // Platforms for the dropdown
    private List<Platform> Platforms { get; set; } = new();

    // To hold the selected platform IDs
    private int? SelectedPlatformId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        Games = await context.Games
            .Include(g => g.GamePlatforms)
            .FirstOrDefaultAsync(g => g.Id == Id);

        Platforms = await context.Platforms
            .OrderBy(p => p.Name)
            .ToListAsync();

        if (Games is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        SelectedPlatformId = Games.GamePlatforms
            .Select(gp => (int?)gp.PlatformId)
            .FirstOrDefault();
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateGames()
    {
        using var context = DbFactory.CreateDbContext();

        var gameToUpdate = await context.Games
            .Include(g => g.GamePlatforms)
            .FirstOrDefaultAsync(g => g.Id == Id);

        if (gameToUpdate is null || Games is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        gameToUpdate.Title = Games.Title;
        gameToUpdate.ReleaseDate = Games.ReleaseDate;
        gameToUpdate.CoverImageURL = Games.CoverImageURL;
        gameToUpdate.Status = Games.Status;

        context.GamePlatforms.RemoveRange(gameToUpdate.GamePlatforms);

        if (SelectedPlatformId.HasValue)
        {
            context.GamePlatforms.Add(new GamePlatform
            {
                GameID = gameToUpdate.Id,
                PlatformId = SelectedPlatformId.Value
            });
        }

        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/games");
    }
}
