@page "/games/create"
@using Microsoft.EntityFrameworkCore
@using BlazorWebAppGames.Models
@inject IDbContextFactory<BlazorWebAppGames.Data.BlazorWebAppGamesContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Games</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Games" OnValidSubmit="AddGames" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <span class="text-danger">*</span>
                <label for="title" class="form-label">Title:</label> 
                <InputText id="title" @bind-Value="Games.Title" class="form-control" aria-required="true"/> 
                <ValidationMessage For="() => Games.Title" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="releasedate" class="form-label">Release Date:</label> 
                <InputDate id="releasedate" @bind-Value="Games.ReleaseDate" class="form-control" /> 
                <ValidationMessage For="() => Games.ReleaseDate" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="coverimageurl" class="form-label">CoverImageURL:</label> 
                <InputText id="coverimageurl" @bind-Value="Games.CoverImageURL" class="form-control" /> 
                <ValidationMessage For="() => Games.CoverImageURL" class="text-danger" /> 
            </div>
            
            <!-- Dropdown for Platform -->
            <div class="mb-3">
                <label for="platform" class="form-label">Platform:</label>
                <InputSelect id="platform" @bind-Value="SelectedPlatformId" class="form-control">
                    <option value="">-- Select Platform --</option>
                    @foreach (var platform in Platforms)
                    {
                        <option value="@platform.Id">@platform.Name</option>
                    }
                </InputSelect>
            </div>

            <!-- Dropdown for Game Status-->
            <div class="mb-3">
                <label for="status" class="form-label">Status:</label>
                <InputSelect id="status" @bind-Value="Games.Status" class="form-control">
                    @foreach (var status in Enum.GetValues<GameStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => Games.Status" class="text-danger" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/games">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Game Games { get; set; } = default!;

    // Platforms for the dropdown
    private List<Platform> Platforms { get; set; } = new();

    // To hold the selected platform IDs
    private int? SelectedPlatformId { get; set; }

    // Method to toggle platform selection
    protected override async Task OnInitializedAsync()
    {
        Games ??= new();

        using var context = DbFactory.CreateDbContext();
        Platforms = await context.Platforms
            .OrderBy(p => p.Name)
            .ToListAsync();
    }

    private async Task AddGames()
    {
        using var context = DbFactory.CreateDbContext();

        context.Games.Add(Games);
        await context.SaveChangesAsync();

        if (SelectedPlatformId.HasValue)
        {
            var gamePlatform = new GamePlatform
            {
                GameID = Games.Id,
                PlatformId = SelectedPlatformId.Value
            };

            context.GamePlatforms.Add(gamePlatform);
            await context.SaveChangesAsync();
        }

        NavigationManager.NavigateTo("/games");
    }
}
